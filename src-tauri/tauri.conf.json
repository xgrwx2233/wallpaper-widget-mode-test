{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wallpaper Widget Mode Test",
  "version": "0.1.0",
  "identifier": "local.wallpaper-widget-mode-test",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "widget",
        "title": "Wallpaper Widget Mode Test",
        "width": 560,
        "height": 260,
        "x": 220,
        "y": 120,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
